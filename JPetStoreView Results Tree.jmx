          <IfController guiclass="IfControllerPanel" testclass="IfController" testname="IF_TOKEN_EXPIRED_OR_MISSING" enabled="true">
            <stringProp name="IfController.condition">${v_tokenAgeInSeconds} &gt;= 840 || &quot;${v_jwtToken}&quot; == &quot;NOT_FOUND&quot;</stringProp>
            <boolProp name="IfController.evaluateAll">false</boolProp>
