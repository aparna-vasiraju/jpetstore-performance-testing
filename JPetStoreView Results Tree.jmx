          <hashTree>
            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="MOCK_OAUTH_LOGIN" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import java.time.Instant

// 1. Simulate a realistic random secure JWT string
String mockJWT = &quot;eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.&quot; + UUID.randomUUID().toString()

// 2. Capture the exact timestamp of when this token was created (in milliseconds)
long currentTimeMillis = Instant.now().toEpochMilli()

// 3. Store these into JMeter variables so the rest of the script can use them
vars.put(&quot;v_jwtToken&quot;, mockJWT)
vars.put(&quot;v_tokenCreatedAt&quot;, String.valueOf(currentTimeMillis))

// 4. Print a friendly message to the JMeter console so we can monitor our progress
log.info(&quot;&gt;&gt;&gt;&gt; [LOGIN] New JWT Issued: &quot; + mockJWT)
log.info(&quot;&gt;&gt;&gt;&gt; [LOGIN] Token Timestamp Recorded: &quot; + currentTimeMillis)

// 5. Provide a mock response body for debugging in the View Results Tree
SampleResult.setResponseData(&apos;&apos;&apos;{
  &quot;token_type&quot;: &quot;Bearer&quot;,
  &quot;access_token&quot;: &quot;&apos;&apos;&apos; + mockJWT + &apos;&apos;&apos;&quot;,
  &quot;expires_in&quot;: 900
}&apos;&apos;&apos;, &quot;UTF-8&quot;)
SampleResult.setResponseOK()</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Sampler>
