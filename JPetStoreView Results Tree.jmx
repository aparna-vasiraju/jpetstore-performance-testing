              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="TOKEN_AGE_CALCULATOR" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">import java.time.Instant

// 1. Fetch the timestamp of when our token was created from JMeter memory
String createdAtStr = vars.get(&quot;v_tokenCreatedAt&quot;)

if (createdAtStr != null) {
    long createdAt = Long.parseLong(createdAtStr)
    long currentTime = Instant.now().toEpochMilli()
    
    // 2. Calculate the difference in milliseconds and convert to seconds
    long ageInSeconds = (currentTime - createdAt) / 1000
    
    // 3. Save the age into a variable so our If Controller can evaluate it
    vars.put(&quot;v_tokenAgeInSeconds&quot;, String.valueOf(ageInSeconds))
    
    log.info(&quot;&gt;&gt;&gt;&gt; [CLOCK] Current Token Age: &quot; + ageInSeconds + &quot; seconds&quot;)
} else {
    // If the token doesn&apos;t exist yet, force age to a high number to trigger login
    vars.put(&quot;v_tokenAgeInSeconds&quot;, &quot;9999&quot;)
}</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PreProcessor>
